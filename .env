# 项目版本号
vite_version = 2.4.9

# 项目后端API地址
vite_project_api = https://txh.rgblog.cn/api

# 百度统计相关配置（可选）
为了更好地追踪和分析您的网站流量，我们提供百度统计的集成服务。以下是相关的配置步骤：

1. **获取百度统计ID**：
   首先，您需要在百度统计网站上注册并获取一个ID。请访问[百度统计官网](https://tongji.baidu.com/)，按照提示完成注册，并获取您的网站ID。

2. **下载百度统计代码**：
   登录您的百度统计账户后，进入“我的网站”页面，找到并复制“通用代码”或“增强代码”。这段代码是集成百度统计的必需步骤。

3. **将代码粘贴到页面**：
   将复制的百度统计代码粘贴到您网站的每个页面的HTML代码中。通常，这可以在每个页面的``标签内完成。确保代码正确无误地放置在页面的头部区域。

4. **配置百度统计**：
   如果您需要更高级的配置，例如自定义变量、事件追踪等，您可以访问百度统计的文档中心，找到相关的配置指南。

5. **验证集成**：
   集成完成后，您可以通过百度统计的“数据概览”功能来验证数据是否正常收集。这可以帮助您确保网站的流量数据能够准确地反映在百度统计报告中。

通过以上步骤，您可以成功地将百度统计集成到您的网站中。这将为您提供宝贵的流量分析数据，帮助您更好地优化网站性能和用户体验。
# 配置教程：https://docs.liuyuyang.net/docs/项目部署/API/百度统计.html
VITE_BAIDU_TONGJI_SITE_ID=
vite_baidu_tongji_access_token =

# 星火AI相关配置（可选）
星火AI相关配置是可选的，用于调整星火AI的行为和性能。这些配置可以在星火AI的设置中找到。
# 配置教程：https://docs.liuyuyang.net/docs/项目部署/API/星火大模型.html
vite_ai_apipassword =
VITE_AI_MODEL=轻量级

